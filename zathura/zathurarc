# --- Settings ---                                                        
set selection-clipboard clipboard # Copy text to system clipboard         
set render-loading        "true"                                          
set scroll-step           100                                             
set font                  "JetBrains Mono 12"                             
                                                                            
# --- Eye Care: Recolor Settings ---                                      
set recolor               "true"                                          
set recolor-keephue       "false" # Set to true if you want to keep image 
colors                                                                      
                                                                            
# Soft Cream on Dark Charcoal (Gruvbox style)                             
set recolor-lightcolor    "#282828" # Background                          
set recolor-darkcolor     "#ebdbb2" # Text/Foreground                     
                                                                            
# Colors for the UI (Status bar, etc.)                                    
set default-bg            "#282828"                                       
set default-fg            "#ebdbb2"                                       
set statusbar-bg          "#3c3836"                                       
set statusbar-fg          "#ebdbb2"                                       
set inputbar-bg           "#282828"                                       
set inputbar-fg           "#fabd2f"                                       
                                                                            
# Highlight colors                                                        
set highlight-color       "#fabd2f"                                       
set highlight-active-color "#fe8019"                                      
                                                                            
# Notification colors                                                     
set notification-error-bg "#fb4934"                                       
set notification-error-fg "#282828"                                       
set notification-warning-bg "#fabd2f"                                     
set notification-warning-fg "#282828"